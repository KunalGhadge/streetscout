// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  collection   String
  collectionTag String  @default("")
  dropNumber   String   @default("DROP-001")
  universe     String
  universeJp   String   @default("")
  price        Float
  description  String
  fabric       String
  fit          String
  breathability String
  durability   String
  sizes        String   @default("XS,S,M,L,XL,XXL")
  imageFront   String
  imageBack    String
  accentColor  String   @default("accent")
  isFeatured   Boolean  @default(false)
  inStock      Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Universe {
  id         String   @id @default(cuid())
  name       String
  japanese   String
  dropNumber String
  image      String
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Drop {
  id          String   @id @default(cuid())
  number      String
  japanese    String
  title       String
  description String
  status      String   @default("AVAILABLE")
  image       String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Lifestyle {
  id          String   @id @default(cuid())
  label       String
  japanese    String
  tag         String
  description String
  image       String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Coupon codes for discounts, free gifts, or free shipping
model Coupon {
  id          String   @id @default(cuid())
  code        String   @unique
  description String   @default("")
  type        String   @default("DISCOUNT") // DISCOUNT | FREE_SHIPPING | FREE_GIFT
  value       Float    @default(0) // percentage for DISCOUNT (e.g. 10 = 10% off)
  giftName    String   @default("") // for FREE_GIFT type
  minOrder    Float    @default(0) // minimum order amount to apply
  usageLimit  Int      @default(0) // 0 = unlimited, N = first N users only
  usedCount   Int      @default(0) // how many times used so far
  isActive    Boolean  @default(true)
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Store order status — pause/stop orders when overwhelmed
model StoreStatus {
  id           String   @id @default(cuid())
  accepting    Boolean  @default(true) // false = orders paused
  message      String   @default("") // custom notification message
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Admin-pushed notifications shown to users
model Notification {
  id        String   @id @default(cuid())
  title     String
  body      String
  type      String   @default("INFO") // INFO | OFFER | COUPON | WARNING
  link      String   @default("") // optional URL to navigate to
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Key-value settings store (WhatsApp number, etc.)
model Setting {
  key       String   @id
  value     String   @default("")
  updatedAt DateTime @updatedAt
}

// Affiliate program — partner with creators who get custom promo codes
model Affiliate {
  id              String   @id @default(cuid())
  code            String   @unique // e.g., NARUTO10 — what customers enter
  creatorName     String   // e.g., @anime_fan_page
  platform        String   @default("Instagram") // Instagram, YouTube, TikTok, etc.
  contact         String   @default("") // WhatsApp/email to reach creator for payout

  // Customer reward (what the buyer gets)
  rewardType      String   @default("DISCOUNT") // DISCOUNT | FREE_GIFT | NONE
  rewardValue     Float    @default(0) // percentage off (e.g., 10 = 10%)
  rewardGiftName  String   @default("") // for FREE_GIFT type

  // Creator commission (what the partner earns per sale)
  commissionType  String   @default("PERCENTAGE") // PERCENTAGE | FIXED
  commissionValue Float    @default(10) // % of order total OR fixed ₹ amount

  isActive        Boolean  @default(true)
  orders          AffiliateOrder[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Track every order that used an affiliate code
// This is the "source of truth" for payouts — only CONFIRMED orders count
model AffiliateOrder {
  id              String   @id @default(cuid())
  affiliateId     String
  affiliate       Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  code            String   // snapshot of the code used (in case affiliate is deleted)
  creatorName     String   // snapshot of creator name
  customerName    String   @default("") // who placed the order
  customerPhone   String   @default("") // customer's phone number
  orderTotal      Float    // final total after discount
  commissionDue   Float    // calculated commission amount in ₹
  status          String   @default("PENDING") // PENDING | CONFIRMED | CANCELLED
  customerNote    String   @default("") // optional note (e.g., "out of stock")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
