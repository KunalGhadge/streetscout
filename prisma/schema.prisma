// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // LOCAL DEV: SQLite (current setup)
  // PRODUCTION (Vercel): Change "sqlite" to "postgresql" before deploying
  // See README.md → "Deployment to Vercel" section for instructions
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  collection   String
  collectionTag String  @default("")
  dropNumber   String   @default("DROP-001")
  universe     String
  universeJp   String   @default("")
  price        Float
  description  String
  fabric       String
  fit          String
  breathability String
  durability   String
  sizes        String   @default("XS,S,M,L,XL,XXL")
  imageFront   String
  imageBack    String
  accentColor  String   @default("accent")
  isFeatured   Boolean  @default(false)
  inStock      Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Universe {
  id         String   @id @default(cuid())
  name       String
  japanese   String
  dropNumber String
  image      String
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Drop {
  id          String   @id @default(cuid())
  number      String
  japanese    String
  title       String
  description String
  status      String   @default("AVAILABLE")
  image       String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Lifestyle {
  id          String   @id @default(cuid())
  label       String
  japanese    String
  tag         String
  description String
  image       String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Coupon codes for discounts, free gifts, or free shipping
model Coupon {
  id          String   @id @default(cuid())
  code        String   @unique
  description String   @default("")
  type        String   @default("DISCOUNT") // DISCOUNT | FREE_SHIPPING | FREE_GIFT
  value       Float    @default(0) // percentage for DISCOUNT (e.g. 10 = 10% off)
  giftName    String   @default("") // for FREE_GIFT type
  minOrder    Float    @default(0) // minimum order amount to apply
  usageLimit  Int      @default(0) // 0 = unlimited, N = first N users only
  usedCount   Int      @default(0) // how many times used so far
  isActive    Boolean  @default(true)
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Store order status — pause/stop orders when overwhelmed
model StoreStatus {
  id           String   @id @default(cuid())
  accepting    Boolean  @default(true) // false = orders paused
  message      String   @default("") // custom notification message
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Admin-pushed notifications shown to users
model Notification {
  id        String   @id @default(cuid())
  title     String
  body      String
  type      String   @default("INFO") // INFO | OFFER | COUPON | WARNING
  link      String   @default("") // optional URL to navigate to
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Key-value settings store (WhatsApp number, etc.)
model Setting {
  key       String   @id
  value     String   @default("")
  updatedAt DateTime @updatedAt
}
