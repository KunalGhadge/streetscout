// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  collection   String
  collectionTag String  @default("")
  dropNumber   String   @default("DROP-001")
  universe     String
  universeJp   String   @default("")
  price        Float
  description  String
  fabric       String
  fit          String
  breathability String
  durability   String
  imageFront   String
  imageBack    String
  accentColor  String   @default("accent")
  isFeatured   Boolean  @default(false)
  inStock      Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Universe {
  id         String   @id @default(cuid())
  name       String
  japanese   String
  dropNumber String
  image      String
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Drop {
  id          String   @id @default(cuid())
  number      String
  japanese    String
  title       String
  description String
  status      String   @default("AVAILABLE")
  image       String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Lifestyle {
  id          String   @id @default(cuid())
  label       String
  japanese    String
  tag         String
  description String
  image       String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
