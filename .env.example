# ===========================================
# Street Scout — Environment Variables
# ===========================================
# Copy this file to .env for local development
# Copy these to Vercel dashboard for production

# ---------- DATABASE ----------
# Local development (SQLite):
DATABASE_URL="file:./db/custom.db"

# Production (Vercel Postgres) — set in Vercel dashboard:
# DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# ---------- ADMIN SECURITY ----------
# Change this to your own strong password
ADMIN_PASSWORD="StreetScout2025!Secure"

# Random secret string for signing session tokens (generate a new one)
ADMIN_SECRET="ss_admin_secret_key_change_me_to_random_string_8f3k2m9x"

# ---------- VERCEL BLOB (Image Storage) ----------
# Only needed in production — automatically set when you create a Blob store in Vercel
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxx"

# ---------- WHATSAPP ----------
# Default WhatsApp number (can be changed in admin panel later)
# Format: country code + number, no + or spaces
# Example: 918451818607 for +91 8451818607
WHATSAPP_NUMBER="918451818607"
